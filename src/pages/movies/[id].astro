---
import { formatYear } from '@/lib/utils';
import { getMovieDetails, getTrendingMovies } from '@/lib/getTrendingMovies';
import Layout from '@/layouts/Layout.astro';

export async function getStaticPaths() {
  const movies = await getTrendingMovies();

  return movies.map((movie) => ({
    params: { id: movie.id },
  }));
}

const { id } = Astro.params;
const movie = id ? await getMovieDetails(id) : null;
const pageTitle = movie ? `${movie.title}` : 'Trending Movies Explorer';
---

<Layout preloadImageUrl={movie?.posterPath ?? undefined} pageTitle={pageTitle}>
  <main class="movie-details">
    <a class="movie-details-back" href="/">← Back to Home</a>

    {
      movie ? (
        <article class="movie-details-card">
          {movie.backdropPath ? (
            <img
              class="movie-details-backdrop"
              src={movie.backdropPath}
              alt={`${movie.title} backdrop`}
              loading="eager"
              fetchpriority="high"
            />
          ) : null}

          <div class="movie-details-content">
            <h1>{movie.title}</h1>
            <p class="movie-details-meta">
              {formatYear(movie.releaseDate)} · Rating {movie.voteAverage.toFixed(1)}
              {movie.runtime ? ` · ${movie.runtime} min` : ''}
            </p>

            {movie.genres.length ? (
              <p class="movie-details-genres">
                {movie.genres.map((genre) => genre.name).join(', ')}
              </p>
            ) : null}

            <p>{movie.overview || 'No overview available.'}</p>
          </div>
        </article>
      ) : (
        <section class="movie-details-empty">
          <h1>Movie not found</h1>
          <p>We couldn’t load this movie right now.</p>
        </section>
      )
    }
  </main>

  <style lang="scss">
    .movie-details {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1rem 3rem;
      display: grid;
      gap: 1rem;
    }

    .movie-details-back {
      justify-self: start;
      border: 1px solid;
      border-radius: 8px;
      padding: 0.45rem 0.7rem;
      color: inherit;
      text-decoration: none;
      font-weight: 600;
    }

    .movie-details-card {
      border: 1px solid;
      border-radius: 14px;
      overflow: hidden;
    }

    .movie-details-backdrop {
      width: 100%;
      aspect-ratio: 16 / 7;
      object-fit: cover;
      display: block;
    }

    .movie-details-content {
      padding: 1rem;
      display: grid;
      gap: 0.85rem;
    }

    .movie-details-content h1,
    .movie-details-content p,
    .movie-details-empty h1,
    .movie-details-empty p {
      margin: 0;
    }

    .movie-details-meta,
    .movie-details-genres {
      opacity: 0.8;
    }

    .movie-details-empty {
      border: 1px dashed;
      border-radius: 14px;
      padding: 1rem;
      display: grid;
      gap: 0.5rem;
    }
  </style>
</Layout>
